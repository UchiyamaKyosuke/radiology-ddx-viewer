      "summary": "脱髄疾患全体として女性に多い傾向がある。"
    },
    "age": {
      "typical_min": 15,
      "typical_max": 55,
      "peak_decade": "20-40歳代",
      "summary": "若年成人から中年に多い。"
    }
  },
